// ─────────────────────────────────────────────────────────────────────────────
// InfluenceHub — Prisma Schema v3
// Auth (FR01–FR05) + User Management (FR06–FR10) + Community (FR11–FR15)
// ─────────────────────────────────────────────────────────────────────────────

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─────────────────────────────────────────────────────────────────────────────
// ENUMS
// ─────────────────────────────────────────────────────────────────────────────

enum Role {
  SYSTEM_ADMIN
  BUSINESS_OWNER
  AGENT
  DIAMOND_INFLUENCER
  GOLD_INFLUENCER
  SILVER_INFLUENCER
}

enum UserStatus {
  ACTIVE
  INACTIVE
  SUSPENDED
  PENDING_VERIFICATION
}

enum VerificationStatus {
  PENDING
  APPROVED
  REJECTED
}

enum InfluencerTier {
  DIAMOND
  GOLD
  SILVER
}

enum AuditAction {
  REGISTER
  LOGIN
  LOGOUT
  LOGOUT_ALL
  REFRESH_TOKEN
  FORGOT_PASSWORD
  VERIFY_RESET_CODE
  RESET_PASSWORD
  VERIFY_EMAIL
  RESEND_VERIFICATION
  FAILED_LOGIN
  ACCOUNT_LOCKED
  ACCOUNT_UNLOCKED
  PROFILE_UPDATED
  PASSWORD_CHANGED
  SUSPICIOUS_ACTIVITY
  // FR06
  USER_CREATED
  USER_UPDATED
  USER_DEACTIVATED
  USER_REACTIVATED
  TIER_ASSIGNED
  // FR08
  BUSINESS_APPROVED
  BUSINESS_REJECTED
  // FR11–FR15
  COMMUNITY_CREATED
  COMMUNITY_UPDATED
  COMMUNITY_DEACTIVATED
  COMMUNITY_DELETED
  COMMUNITY_LEADER_ASSIGNED
  COMMUNITY_MEMBER_ADDED
  COMMUNITY_MEMBER_REMOVED
  COMMUNITY_COMMISSION_UPDATED
}

enum NotificationType {
  BUSINESS_APPROVED
  BUSINESS_REJECTED
  TIER_CHANGED
  ACCOUNT_STATUS_CHANGED
  // FR11–FR15
  COMMUNITY_CREATED
  COMMUNITY_LEADER_ASSIGNED
  COMMUNITY_MEMBER_ADDED
  COMMUNITY_MEMBER_REMOVED
  COMMUNITY_COMMISSION_UPDATED
  GENERAL
}

// ─────────────────────────────────────────────────────────────────────────────
// FR11–FR15 ENUMS
// ─────────────────────────────────────────────────────────────────────────────

enum CommunityStatus {
  ACTIVE
  INACTIVE
}

enum CommunityMemberStatus {
  ACTIVE
  REMOVED
}

// ─────────────────────────────────────────────────────────────────────────────
// USER — Extended with profile relations
// ─────────────────────────────────────────────────────────────────────────────

model User {
  id                   String    @id @default(uuid()) @db.Uuid
  firstName            String    @map("first_name") @db.VarChar(100)
  lastName             String    @map("last_name") @db.VarChar(100)
  email                String    @unique @db.VarChar(255)
  passwordHash         String    @map("password_hash") @db.VarChar(255)
  role                 Role      @default(SILVER_INFLUENCER)
  status               UserStatus @default(PENDING_VERIFICATION)
  emailVerified        Boolean   @default(false) @map("email_verified")
  lastLogin            DateTime? @map("last_login")
  failedLoginAttempts  Int       @default(0) @map("failed_login_attempts")
  lockedUntil          DateTime? @map("locked_until")
  profileImage         String?   @map("profile_image") @db.VarChar(500)
  isSuspended          Boolean   @default(false) @map("is_suspended")
  createdAt            DateTime  @default(now()) @map("created_at")
  updatedAt            DateTime  @updatedAt @map("updated_at")
  deletedAt            DateTime? @map("deleted_at")

  // Auth relations
  refreshTokens        RefreshToken[]
  passwordResets       PasswordReset[]
  emailVerifications   EmailVerification[]
  auditLogs            AuditLog[]

  // Profile relations (FR06–FR10)
  businessProfile      BusinessProfile?
  influencerProfile    InfluencerProfile?
  agentProfile         AgentProfile?
  notifications        Notification[]
  createdByAdmin       User?     @relation("AdminCreatedUsers", fields: [createdBy], references: [id])
  createdBy            String?   @map("created_by") @db.Uuid
  managedUsers         User[]    @relation("AdminCreatedUsers")

  // Community relations (FR11–FR15)
  ledCommunities       Community[]       @relation("CommunityLeader")
  communityMemberships CommunityMember[]

  @@index([email])
  @@index([role])
  @@index([status])
  @@index([deletedAt])
  @@map("users")
}

// ─────────────────────────────────────────────────────────────────────────────
// BUSINESS PROFILE — FR07 Business Owner Registration
// ─────────────────────────────────────────────────────────────────────────────

model BusinessProfile {
  id                   String             @id @default(uuid()) @db.Uuid
  userId               String             @unique @map("user_id") @db.Uuid
  businessName         String             @map("business_name") @db.VarChar(255)
  businessType         String?            @map("business_type") @db.VarChar(100)
  registrationNumber   String?            @map("registration_number") @db.VarChar(100)
  taxId                String?            @map("tax_id") @db.VarChar(100)
  website              String?            @db.VarChar(500)
  phone                String?            @db.VarChar(30)
  address              String?            @db.VarChar(500)
  city                 String?            @db.VarChar(100)
  country              String?            @db.VarChar(100)
  description          String?            @db.Text
  verificationStatus   VerificationStatus @default(PENDING) @map("verification_status")
  verifiedAt           DateTime?          @map("verified_at")
  verifiedBy           String?            @map("verified_by") @db.Uuid  // Admin user ID
  rejectionReason      String?            @map("rejection_reason") @db.Text
  createdAt            DateTime           @default(now()) @map("created_at")
  updatedAt            DateTime           @updatedAt @map("updated_at")
  deletedAt            DateTime?          @map("deleted_at")

  // Relations
  user                 User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  documents            BusinessDocument[]

  @@index([userId])
  @@index([verificationStatus])
  @@index([businessName])
  @@map("business_profiles")
}

// ─────────────────────────────────────────────────────────────────────────────
// BUSINESS DOCUMENT — FR07 Secure document storage
// ─────────────────────────────────────────────────────────────────────────────

model BusinessDocument {
  id                String   @id @default(uuid()) @db.Uuid
  businessProfileId String   @map("business_profile_id") @db.Uuid
  documentType      String   @map("document_type") @db.VarChar(100)  // e.g. "business_license", "tax_cert"
  fileName          String   @map("file_name") @db.VarChar(255)
  fileSize          Int      @map("file_size")                        // bytes
  mimeType          String   @map("mime_type") @db.VarChar(100)
  storagePath       String   @map("storage_path") @db.VarChar(1000)  // private storage path/key
  uploadedAt        DateTime @default(now()) @map("uploaded_at")
  createdAt         DateTime @default(now()) @map("created_at")
  updatedAt         DateTime @updatedAt @map("updated_at")
  deletedAt         DateTime? @map("deleted_at")

  // Relations
  businessProfile   BusinessProfile @relation(fields: [businessProfileId], references: [id], onDelete: Cascade)

  @@index([businessProfileId])
  @@map("business_documents")
}

// ─────────────────────────────────────────────────────────────────────────────
// INFLUENCER PROFILE — FR09 Influencer Tiers
// ─────────────────────────────────────────────────────────────────────────────

model InfluencerProfile {
  id                String         @id @default(uuid()) @db.Uuid
  userId            String         @unique @map("user_id") @db.Uuid
  currentTier       InfluencerTier @default(SILVER) @map("current_tier")
  isCommunityLeader Boolean        @default(false) @map("is_community_leader") // Only DIAMOND can be true
  bio               String?        @db.Text
  niche             String?        @db.VarChar(100)        // e.g. "fashion", "tech", "fitness"
  socialHandles     Json?          @map("social_handles")  // { instagram, tiktok, youtube, etc. }
  followerCount     Int?           @map("follower_count")
  engagementRate    Float?         @map("engagement_rate")
  createdAt         DateTime       @default(now()) @map("created_at")
  updatedAt         DateTime       @updatedAt @map("updated_at")
  deletedAt         DateTime?      @map("deleted_at")

  // Relations
  user              User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  tierHistory       InfluencerTierHistory[]

  @@index([userId])
  @@index([currentTier])
  @@map("influencer_profiles")
}

// ─────────────────────────────────────────────────────────────────────────────
// INFLUENCER TIER HISTORY — FR09 Audit trail for tier changes
// ─────────────────────────────────────────────────────────────────────────────

model InfluencerTierHistory {
  id                  String         @id @default(uuid()) @db.Uuid
  influencerProfileId String         @map("influencer_profile_id") @db.Uuid
  previousTier        InfluencerTier? @map("previous_tier")
  newTier             InfluencerTier @map("new_tier")
  changedBy           String         @map("changed_by") @db.Uuid  // Admin user ID
  reason              String?        @db.VarChar(500)
  createdAt           DateTime       @default(now()) @map("created_at")
  updatedAt           DateTime       @updatedAt @map("updated_at")
  deletedAt           DateTime?      @map("deleted_at")

  // Relations
  influencerProfile   InfluencerProfile @relation(fields: [influencerProfileId], references: [id], onDelete: Cascade)

  @@index([influencerProfileId])
  @@index([createdAt])
  @@map("influencer_tier_history")
}

// ─────────────────────────────────────────────────────────────────────────────
// AGENT PROFILE — FR10 Agent Role
// ─────────────────────────────────────────────────────────────────────────────

model AgentProfile {
  id          String    @id @default(uuid()) @db.Uuid
  userId      String    @unique @map("user_id") @db.Uuid
  agencyName  String?   @map("agency_name") @db.VarChar(255)
  phone       String?   @db.VarChar(30)
  bio         String?   @db.Text
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")
  deletedAt   DateTime? @map("deleted_at")

  // Relations
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("agent_profiles")
}

// ─────────────────────────────────────────────────────────────────────────────
// NOTIFICATION — FR08 In-app notifications
// ─────────────────────────────────────────────────────────────────────────────

model Notification {
  id        String           @id @default(uuid()) @db.Uuid
  userId    String           @map("user_id") @db.Uuid
  type      NotificationType
  title     String           @db.VarChar(255)
  message   String           @db.Text
  isRead    Boolean          @default(false) @map("is_read")
  metadata  Json?
  createdAt DateTime         @default(now()) @map("created_at")
  updatedAt DateTime         @updatedAt @map("updated_at")
  deletedAt DateTime?        @map("deleted_at")

  // Relations
  user      User             @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([isRead])
  @@index([createdAt])
  @@map("notifications")
}

// ─────────────────────────────────────────────────────────────────────────────
// AUTH MODELS (unchanged from FR01–FR05)
// ─────────────────────────────────────────────────────────────────────────────

model RefreshToken {
  id          String    @id @default(uuid()) @db.Uuid
  userId      String    @map("user_id") @db.Uuid
  tokenHash   String    @unique @map("token_hash") @db.VarChar(255)
  deviceInfo  String?   @map("device_info") @db.VarChar(500)
  ipAddress   String?   @map("ip_address") @db.VarChar(45)
  userAgent   String?   @map("user_agent") @db.VarChar(500)
  isRevoked   Boolean   @default(false) @map("is_revoked")
  family      String?   @db.VarChar(100)
  expiresAt   DateTime  @map("expires_at")
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")
  deletedAt   DateTime? @map("deleted_at")

  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([tokenHash])
  @@index([expiresAt])
  @@index([family])
  @@map("refresh_tokens")
}

model PasswordReset {
  id        String    @id @default(uuid()) @db.Uuid
  userId    String    @map("user_id") @db.Uuid
  otpHash   String    @map("otp_hash") @db.VarChar(255)
  isUsed    Boolean   @default(false) @map("is_used")
  expiresAt DateTime  @map("expires_at")
  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  deletedAt DateTime? @map("deleted_at")

  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
  @@map("password_resets")
}

model EmailVerification {
  id        String    @id @default(uuid()) @db.Uuid
  userId    String    @map("user_id") @db.Uuid
  otpHash   String    @map("otp_hash") @db.VarChar(255)
  isUsed    Boolean   @default(false) @map("is_used")
  expiresAt DateTime  @map("expires_at")
  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  deletedAt DateTime? @map("deleted_at")

  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
  @@map("email_verifications")
}

model AuditLog {
  id          String      @id @default(uuid()) @db.Uuid
  userId      String?     @map("user_id") @db.Uuid
  action      AuditAction
  ipAddress   String?     @map("ip_address") @db.VarChar(45)
  userAgent   String?     @map("user_agent") @db.VarChar(500)
  metadata    Json?
  success     Boolean     @default(true)
  createdAt   DateTime    @default(now()) @map("created_at")
  updatedAt   DateTime    @updatedAt @map("updated_at")
  deletedAt   DateTime?   @map("deleted_at")

  user        User?       @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([action])
  @@index([createdAt])
  @@map("audit_logs")
}

// ─────────────────────────────────────────────────────────────────────────────
// COMMUNITY — FR11 Community Creation
// ─────────────────────────────────────────────────────────────────────────────

model Community {
  id                String          @id @default(uuid()) @db.Uuid
  title             String          @unique @db.VarChar(255)
  description       String?         @db.Text
  rules             String?         @db.Text
  status            CommunityStatus @default(ACTIVE)
  communityLeaderId String?         @map("community_leader_id") @db.Uuid
  createdBy         String          @map("created_by") @db.Uuid         // SYSTEM_ADMIN id
  createdAt         DateTime        @default(now()) @map("created_at")
  updatedAt         DateTime        @updatedAt @map("updated_at")
  deletedAt         DateTime?       @map("deleted_at")

  // Relations
  leader            User?           @relation("CommunityLeader", fields: [communityLeaderId], references: [id])
  members           CommunityMember[]
  commission        CommunityCommission?
  commissionHistory CommunityCommissionHistory[]

  @@index([status])
  @@index([communityLeaderId])
  @@index([deletedAt])
  @@map("communities")
}

// ─────────────────────────────────────────────────────────────────────────────
// COMMUNITY MEMBER — FR13 Community Member Management
// ─────────────────────────────────────────────────────────────────────────────

model CommunityMember {
  id          String              @id @default(uuid()) @db.Uuid
  communityId String              @map("community_id") @db.Uuid
  userId      String              @map("user_id") @db.Uuid
  status      CommunityMemberStatus @default(ACTIVE)
  joinedAt    DateTime            @default(now()) @map("joined_at")
  leftAt      DateTime?           @map("left_at")
  addedBy     String              @map("added_by") @db.Uuid             // SYSTEM_ADMIN or Community Leader
  removedBy   String?             @map("removed_by") @db.Uuid
  createdAt   DateTime            @default(now()) @map("created_at")
  updatedAt   DateTime            @updatedAt @map("updated_at")
  deletedAt   DateTime?           @map("deleted_at")

  // Relations
  community   Community           @relation(fields: [communityId], references: [id], onDelete: Cascade)
  user        User                @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([communityId, userId])           // prevent duplicate active memberships
  @@index([communityId])
  @@index([userId])
  @@index([status])
  @@map("community_members")
}

// ─────────────────────────────────────────────────────────────────────────────
// COMMUNITY COMMISSION — FR12 Commission Rules (current active config)
// ─────────────────────────────────────────────────────────────────────────────

model CommunityCommission {
  id                 String    @id @default(uuid()) @db.Uuid
  communityId        String    @unique @map("community_id") @db.Uuid
  platformFee        Float     @map("platform_fee")          // e.g. 20.0  (%)
  leaderPercentage   Float     @map("leader_percentage")     // of remaining after platform fee
  memberPercentage   Float     @map("member_percentage")     // leaderPercentage + memberPercentage = 100
  effectiveFrom      DateTime  @default(now()) @map("effective_from")
  updatedBy          String    @map("updated_by") @db.Uuid   // SYSTEM_ADMIN
  createdAt          DateTime  @default(now()) @map("created_at")
  updatedAt          DateTime  @updatedAt @map("updated_at")
  deletedAt          DateTime? @map("deleted_at")

  // Relations
  community          Community @relation(fields: [communityId], references: [id], onDelete: Cascade)

  @@index([communityId])
  @@map("community_commissions")
}

// ─────────────────────────────────────────────────────────────────────────────
// COMMUNITY COMMISSION HISTORY — FR12 Immutable history for auditing
// Historical records are never modified — new record on every change.
// ─────────────────────────────────────────────────────────────────────────────

model CommunityCommissionHistory {
  id                 String    @id @default(uuid()) @db.Uuid
  communityId        String    @map("community_id") @db.Uuid
  platformFee        Float     @map("platform_fee")
  leaderPercentage   Float     @map("leader_percentage")
  memberPercentage   Float     @map("member_percentage")
  effectiveFrom      DateTime  @map("effective_from")
  effectiveTo        DateTime? @map("effective_to")          // null = currently active
  changedBy          String    @map("changed_by") @db.Uuid
  changeReason       String?   @map("change_reason") @db.VarChar(500)
  createdAt          DateTime  @default(now()) @map("created_at")
  updatedAt          DateTime  @updatedAt @map("updated_at")
  deletedAt          DateTime? @map("deleted_at")

  // Relations
  community          Community @relation(fields: [communityId], references: [id], onDelete: Cascade)

  @@index([communityId])
  @@index([effectiveFrom])
  @@map("community_commission_history")
}
