# ─────────────────────────────────────────────────────────────────────────────
# Test Environment — used when NODE_ENV=test with real database
# Create the test DB first: CREATE DATABASE influencehub_test;
# Run: npx dotenv -e .env.test -- npx jest --runInBand
# ─────────────────────────────────────────────────────────────────────────────

NODE_ENV=test
PORT=5001

# Use a SEPARATE test database — never run tests against production data
DATABASE_URL="postgresql://postgres:2123@localhost:5432/influencehub_test?schema=public"

# JWT — short secrets are fine for tests
JWT_ACCESS_SECRET=test_access_secret_min_64_chars_long_abcdefghijklmnopqrstuvwxyz1234
JWT_REFRESH_SECRET=test_refresh_secret_min_64_chars_long_abcdefghijklmnopqrstuvwxyz12
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=30d

# Redis (optional for tests — blacklisting degrades gracefully)
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# SMTP — disable for tests
SMTP_HOST=localhost
SMTP_PORT=1025
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=

# Security
BCRYPT_ROUNDS=4
MAX_LOGIN_ATTEMPTS=5
LOCK_TIME_MINUTES=30
OTP_EXPIRES_MINUTES=10
RATE_LIMIT_MAX=9999

# Logging
LOG_LEVEL=error
LOG_DIR=
